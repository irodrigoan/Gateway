# Runtime environment: "development" or "production"
NODE_ENV=development

# Port the gateway listens on (injected automatically on Railway)
PORT=3333

# Public key (base64) used to verify the JWT signatures
JWT_PUBLIC_KEY=

# URL of the auth service that /auth is forwarded to
AUTH_SERVICE_URL=

# URL of the users service that /users is forwarded to
USERS_SERVICE_URL=

# Allowed CORS origins: "*" to allow all, or a comma-separated
# list (e.g. https://app.com,https://admin.app.com)
CORS_ORIGIN=*
